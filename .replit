modules = ["python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start HTTP Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Test OpenAI Setup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Main Script"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Parser Test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run AIFL Tests"

[[workflows.workflow]]
name = "Start HTTP Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m http.server 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Test OpenAI Setup"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_openai.py"

[[workflows.workflow]]
name = "Run Main Script"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow]]
name = "Run Tests"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m unittest"

[[workflows.workflow]]
name = "Run Parser Test"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_parser.py"

[[workflows.workflow]]
name = "Run AIFL Tests"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m unittest tests/test_aifl_processing.py"

[deployment]
run = ["sh", "-c", "python -m http.server 8000"]

[[ports]]
localPort = 8000
externalPort = 80

[nix]
channel = "stable-24_05"
